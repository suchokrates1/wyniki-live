{
  "name": "wyniki-live-frontend",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:i18n": "node scripts/validate-i18n.mjs",
    "check:public": "npm run test:i18n && npm run build",
    "smoke:public": "node scripts/public-smoke.mjs",
    "smoke:office": "node scripts/office-smoke.mjs",
    "smoke:office:production": "node scripts/office-smoke.mjs --base-url https://score.vestmedia.pl --slot 3",
    "smoke:production": "node scripts/public-smoke.mjs --base-url https://score.vestmedia.pl",
    "test:a11y:public": "node scripts/a11y-public.mjs --skip-contrast",
    "test:a11y:public:full": "node scripts/a11y-public.mjs",
    "test:a11y:public:production": "node scripts/a11y-public.mjs --base-url https://score.vestmedia.pl --report reports/a11y-public-production.json",
    "verify:production": "npm run check:public && npm run smoke:production && npm run smoke:office:production"
  },
  "dependencies": {
    "alpinejs": "^3.13.3",
    "daisyui": "^4.4.19"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "baseline-browser-mapping": "^2.10.32",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^8.0.14"
  },
  "overrides": {
    "glob": "13.0.6"
  }
}
